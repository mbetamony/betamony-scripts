# -----------------------------------------------------------------------------
# Stress / harvest / k6 — copy this file to .env in this folder and adjust values.
# The npm script `npm run stress` uses: export $(cat .env | xargs)
# Avoid spaces in values; use URL-encoded emails where the app expects them.
# -----------------------------------------------------------------------------

# --- Shared (harvest-steps.js + k6 stress.js) ---
# Lean / Literatum host (browser flows, upload URL prefix).
BASE_URL=https://your-lean-host.example

# Journal and submission type used by GraphQL create / stress paths.
JOURNAL_ID=00000000-0000-0000-0000-000000000000
TYPE_ID=your-type-id

# --- k6 only (stress.js) — required for API calls against manuscripts-api ---
MANUSCRIPTS_API_BASE=https://your-manuscripts-api-host.example

# --- harvest (harvest-steps.js) — required when MODE=upload ---
# Path to base64-encoded zip uploaded in the upload scenario (not the CLDR package/ folder).
PACKAGE_PATH=./package.b64

# --- harvest — required ---
# Playwright harvest output JSON (MODE=upload uses PKG, MODE=blank uses BLANK).
RECORDED_STEPS_PKG=./recorded_steps_pkg.json
RECORDED_STEPS_BLANK=./recorded_steps_blank.json

# --- harvest — optional (default upload) ---
# upload | blank — blank uses ARTEMIS_EMAIL; upload uses QA_EMAIL and PACKAGE_PATH.
MODE=upload

# --- Shared — QA vs Artemis test users (URL-encoded emails if your gate expects that) ---
QA_EMAIL=your-qa-user%40example.com
ARTEMIS_EMAIL=your-artemis-user%40example.com

# --- k6 only — optional (default true) ---
# true | false — whether the blank workflow loops editing.
REPEAT_BLANK=true

# --- Optional: human-readable label only (not read by scripts today) ---
# TARGET_ENV=dev1
